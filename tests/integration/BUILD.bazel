uefi_test(
    name = "real_cirros_cloud_test",
    size = "medium",
    arch = "x86_64",
    boot = "direct-kernel",
    cpus = 2,
    debugcon = True,
    forbidden_markers = ["OSTEST: FAIL"],
    host_companion = ":cirros_ssh_probe",
    host_companion_args = ["--debugcon"],
    hostfwd = [qemu_hostfwd(
        name = "ssh",
        guest = 22,
    )],
    initrd = "@cirros_x86_64_initramfs//file",
    kernel = "@cirros_x86_64_kernel//file",
    kernel_args = "console=ttyS0 root=/dev/vda1 ro",
    media = [
        qemu_media(
            name = "root",
            bootindex = 1,
            compression = "none",
            image = "@cirros_x86_64_disk//file",
            image_format = "qcow2",
            readonly = False,
            snapshot = True,
        ),
        qemu_media(
            name = "seed",
            bootindex = None,
            image = ":cirros_seed",
            readonly = True,
        ),
        qemu_scratch_disk(
            name = "scratch",
            export = True,
            size_mb = 8,
        ),
    ],
    memory_mb = 384,
    qemu = ":qemu_system_x86_64",
    qemu_firmware_dir = _QEMU_FIRMWARE_DIR,
    success_markers = [
        "OSTEST: CLOUD USERDATA",
        "OSTEST: CLOUD CPUS 2",
        "OSTEST: DEBUGCON WRITE",
        "OSTEST: SCRATCH WRITE",
        "OSTEST: SCRATCH READBACK",
        "OSTEST: CLOUD PASS",
    ],
    tags = [
        "external",
        "manual",
        "no-remote",
    ],
    timeout_seconds = 90,
)

