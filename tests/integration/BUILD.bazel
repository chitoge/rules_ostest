uefi_test(
    name = "real_qemu_efi_shell_test",
    size = "small",
    arch = "x86_64",
    debugcon = True,
    export_firmware_vars = True,
    firmware = ":ovmf_code",
    firmware_vars = ":ovmf_vars",
    forbidden_markers = ["OSTEST: FAIL"],
    graphics = True,
    media = [qemu_media(
        name = "shell_state",
        bootindex = 1,
        export = True,
        image = ":real_qemu_shell_disk",
        readonly = False,
        snapshot = False,
    )],
    memory_mb = 128,
    phases = [
        {
            "markers": [
                "OSTEST: EFI SHELL",
                "OSTEST: VARIABLE WRITE COMMAND OK",
                "OSTEST: PHASE ONE WRITE",
            ],
            "then": "reboot",
        },
        {
            "markers": [
                "OSTEST: PHASE TWO READ",
                "98B01F10-1F13-4BD2-9173-FAD1C483CC19 - RulesOstestPersistence - 0014 Bytes",
                "4F 53 54 45 53 54 2D 56 41 52 2D 50 45 52 53 49 53 54 45 44",
                "OSTEST: VARIABLE READ COMMAND OK",
                "OSTEST: PASS",
            ],
        },
    ],
    qemu = ":qemu_system_x86_64",
    qemu_firmware_dir = _QEMU_FIRMWARE_DIR,
    screendump_not_blank = True,
    tags = [
        "external",
        "manual",
        "no-remote",
    ],
    timeout_seconds = 30,
)

